<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-blue-100 to-purple-200">
  <div class="backdrop-blur-md bg-white/30 border border-white/40 shadow-xl rounded-3xl p-10 w-full max-w-md text-center">
    <h1 class="text-3xl font-bold text-white drop-shadow-md">Bienvenue sur <span class="text-purple-100">TimeSplit</span></h1>
    <p class="mt-4 text-white/80">Planifiez vos rendez-vous avec élégance.</p>
    
    <% if user_signed_in? %>
      <p class="mt-6 text-white/70">Connecté en tant que <strong><%= current_user.email %></strong></p>
      <%= link_to "Aller au dashboard", "#", class: "mt-4 inline-block bg-white/20 hover:bg-white/30 text-white px-6 py-2 rounded-lg transition" %>
      <%= link_to "Déconnexion", destroy_user_session_path, method: :delete, class: "block mt-2 text-sm text-white/60 hover:underline" %>
    <% else %>
      <%= link_to "Connexion", new_user_session_path, class: "mt-6 inline-block bg-white/20 hover:bg-white/30 text-white px-6 py-2 rounded-lg backdrop-blur-sm transition" %>
    <% end %>
  </div>
</div>